rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function me() {
      return request.auth.uid;
    }

    // ===== SALONS =====
    match /salons/{salonId} {
      allow read: if true;

      allow create: if isAuth()
        && me() == salonId
        && request.resource.data.owner == me()
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 100
        && request.resource.data.city is string;

      // المالك يعدّل أي شيء — الزبون يعدّل rating/reviews فقط (للتقييمات)
      allow update: if isAuth() && (
        me() == salonId
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviews'])
      );

      allow delete: if false;
    }

    // ===== BOOKINGS =====
    match /bookings/{bookingId} {
      // الزبون يرى حجوزاته فقط، وصاحب الصالون يرى حجوزات صالونه فقط
      allow read: if isAuth() && (
        resource.data.user    == me() ||
        resource.data.salonId == me()
      );

      allow create: if isAuth()
        && request.resource.data.user    == me()
        && request.resource.data.userId  == me()
        && request.resource.data.status  == 'pending'
        && request.resource.data.total   is number
        && request.resource.data.total   > 0
        && request.resource.data.total   < 1000
        && request.resource.data.salonId is string;

      allow update: if isAuth() && (
        resource.data.user    == me() ||
        resource.data.salonId == me()
      );

      allow delete: if false;
    }

    // ===== NOTIFICATIONS =====
    match /notifications/{notifId} {
      allow read:   if isAuth() && resource.data.to == me();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.to == me();
      allow delete: if false;
    }

    // ===== حظر كل شيء آخر =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
